# FreeTranscriptAI - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# ---- Database ----
# For development: DATABASE_URL="file:./dev.db"
# For production: Use PostgreSQL
DATABASE_URL="file:./dev.db"

# ---- NextAuth.js ----
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth ----
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add authorized redirect URIs: NEXTAUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---- Deepgram (AI Transcription) ----
# Sign up at https://deepgram.com to get API key
# Free tier includes 200,000 seconds of transcription
DEEPGRAM_API_KEY="your-deepgram-api-key"

# ===========================================
# OPTIONAL - PAYMENTS & ADS
# ===========================================

# ---- Stripe (Payment Processing) ----
# Sign up at https://stripe.com to get API keys
# Create products/pricing in Stripe Dashboard
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
STRIPE_PRO_PRICE_ID="your-stripe-price-id"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# ---- Google AdSense (Monetization) ----
# Sign up at https://adsense.google.com
# Create ad units and get client ID and ad slot IDs
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
NEXT_PUBLIC_GOOGLE_ADSENSE_AD_SLOT="1234567890"

# ===========================================
# CONFIGURATION
# ===========================================

# App URL (use https://your-domain.com for production)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---- Redis (Optional - for production rate limiting) ----
# REDIS_URL="redis://user:password@host:port"

# ===========================================
# OPTIONAL - MONITORING
# ===========================================

# ---- Sentry (Error Tracking) ----
# Sign up at https://sentry.io to get org and project
# SENTRY_ORG="your-organization"
# SENTRY_PROJECT="freetranscriptai"
# SENTRY_AUTH_TOKEN="your-auth-token"
