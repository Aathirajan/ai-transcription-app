# Development environment configuration
# Copy this to .env and update values

NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-key-min-32-chars-for-development-only"

# OAuth (use test credentials)
GOOGLE_CLIENT_ID="test-client-id"
GOOGLE_CLIENT_SECRET="test-client-secret"

# Deepgram (use test key)
DEEPGRAM_API_KEY="test-deepgram-key"

# AdSense (use test ads)
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxx"
NEXT_PUBLIC_GOOGLE_ADSENSE_AD_SLOT="1234567890"

# Stripe (use test mode)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_test_xxxxxxxxxxxxxx"
STRIPE_PRO_PRICE_ID="price_test_xxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxx"

# App
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Redis (optional)
# REDIS_URL="redis://localhost:6379"
