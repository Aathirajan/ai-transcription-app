# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build output
/.next/
/out/
/build

# test output
/coverage

# environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# keep env examples and documentation files in repo
!.env.example

# editor + IDE
/.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated
.DS_Store
Thumbs.db

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# deployment
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

